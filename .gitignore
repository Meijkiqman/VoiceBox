# python
__pycache__/
*.pyc

# build output (rebuild with setup/Build-Setup.bat)
build/
dist/
*.spec

# personal media - soundboard clips stay local
sounds/*
!sounds/.gitkeep

# TTS - personal phrases + rendered speech cache stay local
tts_phrases.json
tts_cache/

# AI voice - RVC runtime + voice models (~12 GB of binaries, stays local)
rvc/

# logs / local junk
*.log

# personal dialing - restored on launch, stays local
settings.json
user_presets.json

# recordings stay local
recordings/
