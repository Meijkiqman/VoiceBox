    "up":         ["up", "w"],
    "down":       ["down", "s"],
    "left":       ["left", "a"],
    "right":      ["right", "d"],
    "select":     ["return", "space"],
    "back":       ["escape"],
    "stop_clips": ["0", "backspace"],
    "mute":       ["m"],
    "page_next":  ["tab", "]"],
    "page_prev":  ["["],
    "clips":      ["1", "2", "3", "4", "5", "6", "7", "8", "9"]
