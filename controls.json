    "up":         ["up", "w"],
    "down":       ["down", "s"],
    "left":       ["left", "a"],
    "right":      ["right", "d"],
    "select":     ["return", "space"],
    "back":       ["escape"],
    "stop_clips": ["0", "backspace"],
    "clips":      ["1", "2", "3", "4", "5", "6", "7", "8", "9"]
  },
  "gamepad": {
    "select":         [0],
    "back":           [1],
    "stop_clips":     [3],
    "axis_threshold": 0.5,
    "nav_cooldown":   0.22
  }
}
