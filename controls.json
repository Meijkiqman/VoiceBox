    "enabled":     true,
    "clips":       ["ctrl+alt+1", "ctrl+alt+2", "ctrl+alt+3",
                    "ctrl+alt+4", "ctrl+alt+5", "ctrl+alt+6",
                    "ctrl+alt+7", "ctrl+alt+8", "ctrl+alt+9"],
    "stop_clips":  "ctrl+alt+0",
